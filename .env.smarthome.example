# 智能家居环境变量配置模板
# 复制此文件为 .env.smarthome 并填写实际值

# ============================================================================
# DeerFlow 基础配置
# ============================================================================
DEER_FLOW_ROOT=/path/to/deer-flow
DEER_FLOW_CONFIG_PATH=/path/to/deer-flow/config.yaml

# ============================================================================
# Home Assistant 配置
# ============================================================================
HOMEASSISTANT_URL=http://homeassistant:8123
HOMEASSISTANT_TOKEN=your_homeassistant_long_lived_access_token_here

# 获取 Home Assistant Token 的步骤：
# 1. 打开 Home Assistant Web 界面
# 2. 点击左侧菜单 → 用户设置（最下方）→ 滚动到底部 → 长期访问令牌
# 3. 点击创建令牌，输入名称（如 "DeerFlow"）
# 4. 复制生成的 token 到此处

# ============================================================================
# MQTT 配置
# ============================================================================
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# 如果使用公共 MQTT broker，更新以下配置：
# MQTT_BROKER=broker.emqx.io
# MQTT_PORT=1883
# MQTT_USERNAME=your_username
# MQTT_PASSWORD=your_password

# ============================================================================
# 模型配置
# ============================================================================
# OpenAI
# OPENAI_API_KEY=your_openai_api_key

# Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Gemini
# GEMINI_API_KEY=your_gemini_api_key

# 其他模型...

# ============================================================================
# 数据库配置（可选）
# ============================================================================
# POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/smarthome
# REDIS_URL=redis://redis:6379

# ============================================================================
# 网页搜索（可选）
# ============================================================================
# TAVILY_API_KEY=your_tavily_api_key
# INFOQUEST_API_KEY=your_infoquest_api_key

# ============================================================================
# 时区配置
# ============================================================================
TZ=Asia/Shanghai

# ============================================================================
# Docker 配置
# ============================================================================
APT_MIRROR=
UV_IMAGE=ghcr.io/astral-sh/uv:0.7.20
UV_INDEX_URL=https://pypi.org/simple

# ============================================================================
# 安全配置
# ============================================================================
# 允许的主机 bash 执行（危险！仅在完全信任的环境启用）
# ALLOW_HOST_BASH=false

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=info
